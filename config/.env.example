# HelloAgents Go 配置示例
# 请复制此文件为 .env 并填入实际的API密钥

# ===================
# LLM 配置
# ===================

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云DashScope (通义千问)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ModelScope
MODELSCOPE_API_KEY=ms-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Kimi (月之暗面)
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 智谱AI (Zhipu/GLM)
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===================
# 本地模型配置
# ===================

# Ollama (本地)
OLLAMA_HOST=http://localhost:11434

# vLLM (本地)
VLLM_HOST=http://localhost:8000

# ===================
# 统一LLM配置 (可选)
# ===================

# 默认模型
LLM_MODEL_ID=gpt-3.5-turbo

# 自定义API地址
LLM_BASE_URL=https://api.openai.com/v1

# 统一API Key
LLM_API_KEY=

# 超时时间(秒)
LLM_TIMEOUT=60

# ===================
# Embedding 配置
# ===================

# 嵌入模型类型: dashscope, local, tfidf
EMBED_MODEL_TYPE=dashscope

# 嵌入模型名称
EMBED_MODEL_NAME=text-embedding-v3

# 嵌入API Key
EMBED_API_KEY=

# 嵌入API地址(可选)
EMBED_BASE_URL=

# ===================
# 数据库配置 (可选)
# ===================

# Qdrant向量数据库
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# Neo4j图数据库
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password-here

# ===================
# 记忆系统配置
# ===================

MEMORY_STORAGE_PATH=./memory_data
MEMORY_MAX_CAPACITY=100
MEMORY_WORKING_CAPACITY=10
MEMORY_WORKING_TTL=120

# ===================
# 日志配置
# ===================

LOG_LEVEL=INFO
DEBUG=false